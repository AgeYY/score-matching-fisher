{
  "latex-workshop.latex.tools": [
    {
      "name": "pdflatex",
      "command": "/usr/bin/pdflatex",
      "args": [
        "-synctex=1",
        "-interaction=nonstopmode",
        "-file-line-error",
        "-output-directory=%OUTDIR%",
        "%DOC%"
      ],
      "env": {}
    }
  ],
  "latex-workshop.latex.recipes": [
    {
      "name": "pdflatex (workspace)",
      "tools": ["pdflatex", "pdflatex"]
    }
  ],
  "latex-workshop.latex.recipe.default": "pdflatex (workspace)"
}
